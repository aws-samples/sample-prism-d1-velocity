#!/usr/bin/env bash
# prepare-commit-msg — add AI-origin trailers to commit messages.
#
# All detection, token accounting, and cost math now live in
# `prism-cli git commit-trailers` (Node). This keeps the hook fully portable
# (Linux/macOS/Windows Git Bash) with NO dependency on jq, bc, sed, or grep -P.
# Token tracking powered by codeburn / prism-cli.
#
# Installation: prism-cli bootstrapper install-git-hooks

set -uo pipefail

COMMIT_MSG_FILE="$1"
COMMIT_SOURCE="${2:-}"

# Skip merge and squash commits
if [[ "${COMMIT_SOURCE}" == "merge" || "${COMMIT_SOURCE}" == "squash" ]]; then
    exit 0
fi

# Don't add trailers if they already exist (e.g., user added them manually)
if grep -q '^AI-Origin:' "${COMMIT_MSG_FILE}" 2>/dev/null; then
    exit 0
fi

# prism-cli is required. If it isn't installed, the commit proceeds without
# trailers rather than failing.
if ! command -v prism-cli >/dev/null 2>&1; then
    exit 0
fi

# Delegate everything to prism-cli. It appends the trailers to the commit
# message file directly. Never block the commit on failure.
prism-cli git commit-trailers \
    --commit-msg-file "${COMMIT_MSG_FILE}" \
    --source "${COMMIT_SOURCE}" >/dev/null 2>&1 || true

exit 0
